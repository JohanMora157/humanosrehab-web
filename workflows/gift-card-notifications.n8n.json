{
  "name": "Humanos Rehab - Tarjetas de regalo",
  "nodes": [
    {
      "parameters": {
        "content": "Importa este flujo y reemplaza: 1) URL del Webhook en GIFT_CARD_NOTIFICATION_URL, 2) credenciales de Google Sheets, 3) Spreadsheet ID, 4) URLs/tokens del proveedor de WhatsApp. Eventos esperados: gift_card_created, gift_card_payment_approved, gift_card_claimed.",
        "height": 220,
        "width": 420
      },
      "id": "sticky-setup",
      "name": "Instrucciones",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -760,
        -220
      ]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "humanos/gift-card-notifications",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-gift-card",
      "name": "Recibir evento tarjeta",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        -760,
        100
      ],
      "webhookId": "REEMPLAZAR-AL-IMPORTAR"
    },
    {
      "parameters": {
        "jsCode": "const payload = $json.body ?? $json;\nconst giftCard = payload.giftCard ?? {};\nconst event = payload.event ?? \"unknown\";\n\nreturn [\n  {\n    json: {\n      event,\n      source: payload.source ?? \"humanosrehab-web\",\n      receivedAt: payload.timestamp ?? new Date().toISOString(),\n      id: giftCard.id ?? \"\",\n      createdAt: giftCard.createdAt ?? \"\",\n      expiresAt: giftCard.expiresAt ?? \"\",\n      paymentStatus: giftCard.paymentStatus ?? \"pending\",\n      cardStatus: giftCard.cardStatus ?? \"inactive\",\n      claimStatus: giftCard.claimStatus ?? \"pending\",\n      buyerName: giftCard.buyerName ?? \"\",\n      buyerPhone: giftCard.buyerPhone ?? \"\",\n      recipientName: giftCard.recipientName ?? \"\",\n      giftType: giftCard.giftType ?? \"\",\n      amount: giftCard.amount ?? \"\",\n      message: giftCard.message ?? \"\",\n      paymentProvider: giftCard.paymentProvider ?? \"\",\n      paymentId: giftCard.paymentId ?? \"\",\n      preferenceId: giftCard.preferenceId ?? \"\",\n      claimedAt: giftCard.claimedAt ?? \"\",\n      notes: giftCard.notes ?? \"\",\n      teamMessage: [\n        \"Nueva actualizacion de tarjeta de regalo\",\n        `Evento: ${event}`,\n        `ID: ${giftCard.id ?? \"\"}`,\n        `Comprador: ${giftCard.buyerName ?? \"\"}`,\n        `WhatsApp comprador: ${giftCard.buyerPhone ?? \"\"}`,\n        `Recibe: ${giftCard.recipientName ?? \"\"}`,\n        `Regalo: ${giftCard.giftType ?? \"\"}`,\n        `Valor: ${giftCard.amount ?? \"\"}`,\n        `Pago: ${giftCard.paymentStatus ?? \"pending\"}`,\n        `Reclamo: ${giftCard.claimStatus ?? \"pending\"}`\n      ].join(\"\\n\"),\n      buyerApprovedMessage: [\n        \"Hola, tu tarjeta de regalo de Humanos Rehab fue activada.\",\n        `ID: ${giftCard.id ?? \"\"}`,\n        `Para: ${giftCard.recipientName ?? \"\"}`,\n        `Regalo: ${giftCard.giftType ?? \"\"}`,\n        `Vence: ${giftCard.expiresAt ?? \"\"}`,\n        \"Puedes compartirla con la persona que recibira el regalo.\"\n      ].join(\"\\n\")\n    }\n  }\n];"
      },
      "id": "code-normalize",
      "name": "Normalizar datos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -520,
        100
      ]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.event }}",
                    "rightValue": "gift_card_created",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              }
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.event }}",
                    "rightValue": "gift_card_payment_approved",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              }
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.event }}",
                    "rightValue": "gift_card_claimed",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              }
            }
          ]
        },
        "options": {}
      },
      "id": "switch-event",
      "name": "Separar por evento",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [
        -280,
        100
      ]
    },
    {
      "parameters": {
        "operation": "append",
        "documentId": {
          "__rl": true,
          "value": "REEMPLAZAR_SPREADSHEET_ID",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Tarjetas",
          "mode": "name"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "id_tarjeta": "={{ $json.id }}",
            "fecha_creacion": "={{ $json.createdAt }}",
            "fecha_vencimiento": "={{ $json.expiresAt }}",
            "estado_pago": "={{ $json.paymentStatus }}",
            "estado_tarjeta": "={{ $json.cardStatus }}",
            "estado_reclamo": "={{ $json.claimStatus }}",
            "nombre_comprador": "={{ $json.buyerName }}",
            "telefono_comprador": "={{ $json.buyerPhone }}",
            "nombre_destinatario": "={{ $json.recipientName }}",
            "tipo_bono": "={{ $json.giftType }}",
            "valor": "={{ $json.amount }}",
            "mensaje": "={{ $json.message }}",
            "payment_provider": "={{ $json.paymentProvider }}",
            "payment_id": "={{ $json.paymentId }}",
            "preference_id": "={{ $json.preferenceId }}",
            "fecha_reclamada": "={{ $json.claimedAt }}",
            "observaciones": "={{ $json.notes }}"
          }
        },
        "options": {}
      },
      "id": "sheets-append-created",
      "name": "Google Sheets - Crear tarjeta",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.6,
      "position": [
        0,
