      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "REEMPLAZAR_CREDENCIAL_GOOGLE",
          "name": "Google Sheets OAuth2"
        }
      }
    },
    {
      "parameters": {
        "content": "Para actualizaciones de pago/reclamo, este template registra el evento en la hoja Eventos. Si quieres que la hoja Tarjetas quede siempre actualizada por fila, agrega despues de este nodo un Lookup por id_tarjeta y luego un Update Row sobre la hoja Tarjetas.",
        "height": 180,
        "width": 380
      },
      "id": "sticky-update-note",
      "name": "Nota actualizacion Sheets",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        180,
        -220
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://REEMPLAZAR_PROVEEDOR_WHATSAPP/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer REEMPLAZAR_TOKEN_WHATSAPP"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"to\": \"={{ $json.buyerPhone }}\",\n  \"message\": \"={{ $json.buyerApprovedMessage }}\"\n}",
        "options": {}
      },
      "id": "notify-buyer",
      "name": "WhatsApp comprador - Pago aprobado",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        0,
        120
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://REEMPLAZAR_PROVEEDOR_WHATSAPP/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
