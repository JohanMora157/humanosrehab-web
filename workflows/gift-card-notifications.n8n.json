              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"to\": \"REEMPLAZAR_WHATSAPP_EQUIPO\",\n  \"message\": \"={{ $json.teamMessage }}\"\n}",
        "options": {}
      },
      "id": "notify-team",
      "name": "WhatsApp equipo",
      "type": "n8n-nodes-base.httpRequest",
